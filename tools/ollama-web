#!/usr/bin/env bash
# ollama-web — ollama wrapper with native tool-calling (search + fetch + bash)
# Uses /api/chat with tools JSON schema — works on qwen2.5, llama3.1, mistral-nemo, etc.
#
# Usage: ollama-web -p "prompt" [--model MODEL] [--num-ctx N]

set -euo pipefail

MODEL="qwen2.5:14b"
PROMPT=""
MAX_ROUNDS=10
NUM_CTX="${OLLAMA_NUM_CTX:-8192}"
OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p) PROMPT="$2"; shift 2 ;;
        --model) MODEL="$2"; shift 2 ;;
        --num-ctx) NUM_CTX="$2"; shift 2 ;;
        *) PROMPT="$1"; shift ;;
    esac
done

if [[ -z "$PROMPT" ]]; then
    echo "Usage: ollama-web -p \"prompt\" [--model MODEL] [--num-ctx N]" >&2
    exit 1
fi

# --- Tool implementations ---

do_search() {
    local query="$1"
    if command -v ddgr &>/dev/null; then
        ddgr --np -n 5 --json "$query" 2>/dev/null | head -c 4000
    else
        local encoded
        encoded=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$query")
        curl -s "https://lite.duckduckgo.com/lite/?q=$encoded" \
            | python3 -c "
import sys, re, html
text = sys.stdin.read()
results = re.findall(r'<a[^>]*href=\"(https?://[^\"]+)\"[^>]*>([^<]+)</a>', text)
for url, title in results[:5]:
    print(f'{html.unescape(title).strip()}: {url}')
" 2>/dev/null | head -c 4000
    fi
}

do_bash() {
    local cmd="$1"
    # Sandbox writes to CWD + tmp dirs only. Reads + network stay open so
    # binaries, libs, git/curl, etc. still work. Falls back to unsandboxed
    # if sandbox-exec is unavailable (non-macOS).
    if command -v sandbox-exec &>/dev/null; then
        local profile
        profile=$(mktemp -t ollama-web-sb.XXXXXX.sb)
        trap "rm -f '$profile'" RETURN
        cat > "$profile" <<EOF
(version 1)
(allow default)
(deny file-write*)
(allow file-write*
    (subpath "$PWD")
    (subpath "/tmp")
    (subpath "/private/tmp")
    (subpath "/private/var/folders")
    (subpath "/dev"))
EOF
        { sandbox-exec -f "$profile" bash -c "$cmd" 2>&1 || true; } | head -c 4000
    else
        { bash -c "$cmd" 2>&1 || true; } | head -c 4000
    fi
}

do_fetch() {
    local url="$1"
    curl -sL --max-time 10 --max-filesize 1048576 "$url" 2>/dev/null \
        | python3 -c "
import sys, re, html
raw = sys.stdin.read()
text = re.sub(r'<script[^>]*>.*?</script>', '', raw, flags=re.DOTALL)
text = re.sub(r'<style[^>]*>.*?</style>', '', text, flags=re.DOTALL)
text = re.sub(r'<[^>]+>', ' ', text)
text = html.unescape(text)
text = re.sub(r'\s+', ' ', text).strip()
print(text[:6000])
" 2>/dev/null
}

# --- Tool schema (passed to Ollama on every request) ---

TOOLS='[
  {
    "type": "function",
    "function": {
      "name": "search",
      "description": "Search the web for current information",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "Search query"}
        },
        "required": ["query"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "fetch",
      "description": "Fetch and read the content of a URL",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {"type": "string", "description": "URL to fetch"}
        },
        "required": ["url"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "bash",
      "description": "Execute a shell command and return its output. Use this to run collab commands (e.g. collab todo add, collab add, collab list), read/write files, or perform any shell operation.",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {"type": "string", "description": "Shell command to execute"}
        },
        "required": ["command"]
      }
    }
  }
]'

# --- Conversation state (JSON array of messages) ---

messages=$(jq -n --arg content "$PROMPT" '[{"role":"user","content":$content}]')

# --- Main loop ---

for round in $(seq 1 $MAX_ROUNDS); do
    raw=$(curl -s "$OLLAMA_HOST/api/chat" \
        -H "Content-Type: application/json" \
        -d "$(jq -n \
            --arg model "$MODEL" \
            --argjson messages "$messages" \
            --argjson tools "$TOOLS" \
            --argjson ctx "$NUM_CTX" \
            '{model:$model, messages:$messages, tools:$tools, stream:false, options:{num_ctx:$ctx}}')")

    # Check for API error
    if echo "$raw" | jq -e '.error' &>/dev/null; then
        echo "Ollama error: $(echo "$raw" | jq -r '.error')" >&2
        exit 1
    fi

    assistant_msg=$(echo "$raw" | jq '.message')
    tool_calls=$(echo "$assistant_msg" | jq '.tool_calls // []')
    content=$(echo "$assistant_msg" | jq -r '.content // ""')

    # Fallback: some models (notably qwen2.5-coder) emit tool calls as JSON in
    # the content field instead of using the structured tool_calls field. Parse
    # them out so the loop can still execute them.
    if [[ "$(echo "$tool_calls" | jq 'length')" -eq 0 && -n "$content" ]]; then
        parsed=$(echo "$content" | python3 -c "
import sys, re, json
text = sys.stdin.read()
calls = []
for m in re.findall(r'\{[\s\S]*?\}(?=\s*\{|\s*\Z)', text) or re.findall(r'\{[\s\S]*\}', text):
    try:
        obj = json.loads(m)
    except Exception:
        continue
    name = obj.get('name') or obj.get('tool') or obj.get('function')
    args = obj.get('arguments') or obj.get('args') or obj.get('parameters') or {}
    if isinstance(name, str) and name in ('search', 'fetch', 'bash'):
        calls.append({'function': {'name': name, 'arguments': args}})
if calls:
    print(json.dumps(calls))
" 2>/dev/null)
        if [[ -n "$parsed" ]]; then
            tool_calls="$parsed"
            assistant_msg=$(echo "$assistant_msg" | jq --argjson tc "$parsed" '.tool_calls = $tc | .content = ""')
        fi
    fi

    # No tool calls — we're done
    if [[ "$(echo "$tool_calls" | jq 'length')" -eq 0 ]]; then
        # If the prompt asks for JSON output, extract the JSON block from the response
        # (models often wrap it in prose or markdown code fences)
        if echo "$PROMPT" | grep -q '"response"'; then
            json_block=$(echo "$content" | python3 -c "
import sys, re, json
text = sys.stdin.read()
# Try to find a JSON object in the output — try progressively smaller matches
# re.findall with greedy pattern returns one big match; use non-greedy fallback too
candidates = []
# Greedy: outermost { to }
candidates += re.findall(r'\{[\s\S]*\}', text)
# Non-greedy: each {...} block separately
candidates += re.findall(r'\{[^{}]*(?:\{[^{}]*\}[^{}]*)?\}', text)
seen = set()
for m in reversed(candidates):
    if m in seen:
        continue
    seen.add(m)
    try:
        obj = json.loads(m)
        if 'response' in obj or 'delegate' in obj or 'continue' in obj:
            # Enforce safe defaults regardless of what the model said
            obj['messages'] = None
            obj['continue'] = False
            print(json.dumps(obj))
            sys.exit(0)
    except Exception:
        pass
# No valid JSON found — wrap raw text as a response so harness always gets valid JSON
print(json.dumps({'response': text.strip() or None, 'delegate': [], 'messages': None, 'completed_tasks': [], 'continue': False, 'state_update': {}}))
" 2>/dev/null)
            echo "$json_block" | tee -a /tmp/ollama-web-debug.log
        else
            echo "$content"
        fi
        exit 0
    fi

    # Append assistant message to history
    messages=$(echo "$messages" | jq --argjson msg "$assistant_msg" '. + [$msg]')

    # Execute each tool call and append results
    num_calls=$(echo "$tool_calls" | jq 'length')
    for i in $(seq 0 $((num_calls - 1))); do
        call=$(echo "$tool_calls" | jq ".[$i]")
        name=$(echo "$call" | jq -r '.function.name')
        args=$(echo "$call" | jq -r '.function.arguments')

        case "$name" in
            search)
                query=$(echo "$args" | jq -r '.query')
                echo "[search: $query]" >&2
                result=$(do_search "$query")
                ;;
            fetch)
                url=$(echo "$args" | jq -r '.url')
                echo "[fetch: $url]" >&2
                result=$(do_fetch "$url")
                ;;
            bash)
                cmd=$(echo "$args" | jq -r '.command')
                echo "[bash: $cmd]" >&2
                result=$(do_bash "$cmd")
                ;;
            *)
                result="Unknown tool: $name"
                ;;
        esac

        messages=$(echo "$messages" | jq \
            --arg result "$result" \
            '. + [{"role":"tool","content":$result}]')
    done
done

# Max rounds hit
echo "$content" >&2
echo "Warning: max rounds ($MAX_ROUNDS) reached" >&2
echo "$content"
